# Directory where job and resume data is stored (created automatically on first run)
DATA_DIR=/home/you/job_data

# Origin of the frontend — used for CORS. Change port if you move the frontend.
FRONTEND_ORIGIN=http://localhost:5173

# Login credentials (optional — leave blank to use the browser setup page on first run)
# AUTH_USERNAME can be any string (default: admin)
AUTH_USERNAME=admin

# Generate with:
#   cd backend && uv run python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
AUTH_PASSWORD_HASH=

# Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET_KEY=

# Optional: how long login tokens stay valid (default: 24 hours)
# AUTH_TOKEN_EXPIRE_HOURS=24
